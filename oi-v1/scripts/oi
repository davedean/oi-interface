#!/bin/bash
# oi — thin shell wrapper around the Python agent helper.
# Usage:
#   oi say "text"
#   oi ask "title" -o yes -o no -o later
#   oi pings
#   oi wait-ping
#   oi clear
#
# Runs the Python module from wherever this script lives.

set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec python3 "$SCRIPT_DIR/../agent/oi.py" "$@"
