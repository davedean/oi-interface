#!/usr/bin/env bash
# Start a pi session wired to the oi device via the project extension.
#
# Examples:
#   scripts/pi-oi
#   OI_SESSION_NAME="oi real test" scripts/pi-oi --model openai-codex/gpt-5.5
#
# The extension registers the session with oi, routes selected tool approvals
# to the device, and polls device-command queues for status/abort/steer/follow_up.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
EXT="$ROOT/extensions/oi-device.ts"

if [[ ! -f "$EXT" ]]; then
    echo "ERROR: missing extension: $EXT" >&2
    exit 1
fi

export OI_SERVER_URL="${OI_SERVER_URL:-http://127.0.0.1:8842}"
export OI_SESSION_ID="${OI_SESSION_ID:-pi-oi-$(date +%Y%m%d-%H%M%S)-$$}"
export OI_SESSION_NAME="${OI_SESSION_NAME:-oi $(basename "$ROOT")}"
export OI_POLL_MS="${OI_POLL_MS:-1000}"
export OI_APPROVE_TIMEOUT_MS="${OI_APPROVE_TIMEOUT_MS:-60000}"
export OI_APPROVE_TOOLS="${OI_APPROVE_TOOLS:-bash,write,edit}"

cd "$ROOT"
echo "[pi-oi] session_id=$OI_SESSION_ID name=$OI_SESSION_NAME server=$OI_SERVER_URL" >&2
exec pi -e "$EXT" "$@"
