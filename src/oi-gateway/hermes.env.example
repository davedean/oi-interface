# oi-gateway Hermes backend env example
#
# Copy this file to `~/.oi/secrets/oi-gateway/hermes.env.local` and fill in
# the values you want the launcher to source when you run:
#   ./start-oi.sh start hermes

OI_HERMES_BASE_URL=http://127.0.0.1:8000
OI_HERMES_API_KEY=replace-with-your-hermes-api-key
OI_HERMES_MODEL=hermes
