# oi-gateway OpenAI STT + local espeak-ng TTS env example
# Copy to `~/.oi/secrets/oi-gateway/openai.env.local` and adjust values.

OI_AGENT_BACKEND=openclaw
OI_OPENCLAW_URL=ws://127.0.0.1:18789
OI_OPENCLAW_TOKEN=replace-with-your-openclaw-token

# STT backend options: whisper | openai | stub
OI_STT_BACKEND=openai
OPENAI_API_KEY=replace-with-your-openai-api-key
OI_OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# TTS backend options: piper | espeak-ng | stub
OI_TTS_BACKEND=espeak-ng
OI_TTS_VOICE=en
