{
  "device_type": "sbc-handheld",
  "capabilities": {
    "input": [
      "buttons",
      "dpad",
      "hold_to_record",
      "confirm_buttons"
    ],
    "display_width": 24,
    "display_height": 8,
    "has_audio_input": true,
    "has_audio_output": true,
    "commands_supported": [
      "display.show_status",
      "display.show_card",
      "audio.cache.put_begin",
      "audio.cache.put_chunk",
      "audio.cache.put_end",
      "audio.play",
      "audio.stop",
      "device.set_brightness",
      "device.mute_until",
      "display.show_progress",
      "display.show_response_delta",
      "character.set_state",
      "device.set_volume",
      "device.set_led"
    ],
    "supports_text_input": false,
    "supports_confirm_buttons": true,
    "supports_scrolling_cards": true,
    "supports_voice": true,
    "max_spoken_duration_s": 120
  },
  "notes": {
    "plain_english": "This is the optimistic generic handheld profile. Real devices can downgrade these fields at runtime if, for example, no USB mic is attached.",
    "audio_input_policy": "Set has_audio_input=false when no microphone is detected.",
    "rendering_policy": "Tune display_width/display_height based on actual renderer and screen readability."
  }
}
