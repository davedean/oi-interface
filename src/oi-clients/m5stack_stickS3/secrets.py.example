"""
WiFi and Gateway Configuration for M5Stack StickS3.

Copy this file to a local `secrets.py` outside the repo tree and fill in
your actual credentials.

SECRETS FILE - DO NOT COMMIT TO VERSION CONTROL!
"""

# WiFi Configuration
WIFI_SSID = "YourNetworkName"
WIFI_PASSWORD = "YourNetworkPassword"

# Gateway Configuration
GATEWAY_HOST = "gateway.local"  # Or another local DNS/mDNS name
GATEWAY_PORT = 8787

# Device Configuration (optional)
# If not set, device ID is generated from MAC address
# DEVICE_ID = "stick-001"

# Audio Configuration (optional)
# VOLUME_LEVEL = 50  # 0-100

# Display Configuration (optional)
# BRIGHTNESS = 255  # 0-255
